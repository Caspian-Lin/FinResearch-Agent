# Use Chinese NPM mirror for faster installs in mainland China.
registry=https://registry.npmmirror.com/

# Use isolated node-linker to avoid pnpm global store issues in some CI environments.
node-linker=isolated

# Pin resolution. Prevents accidental major upgrades of transitive deps.
auto-install-peers=true
strict-peer-dependencies=false

# Share pnpm store across all projects on this machine.
store-dir=~/.local/share/pnpm/store
