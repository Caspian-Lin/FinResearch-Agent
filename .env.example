# =============================================================================
# FinResearch Agent — Environment Variables (Example)
# Copy this file to `.env` and adjust values for your local environment.
# `.env` is git-ignored — never commit real secrets.
#
# Defaults below target LOCAL DEV (no Docker): hosts point at localhost. If you
# run the stack under Docker Compose, set POSTGRES_HOST=postgres and
# REDIS_HOST=redis (the Compose service names).
# =============================================================================

# ---------- PostgreSQL + TimescaleDB ----------
POSTGRES_USER=finresearch
POSTGRES_PASSWORD=finresearch_dev_password
POSTGRES_DB=finresearch
# Local dev: localhost. Docker Compose: postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy DSN used by API, worker, and Alembic
DATABASE_URL=postgresql+psycopg://finresearch:finresearch_dev_password@localhost:5432/finresearch

# ---------- Redis ----------
# Local dev: localhost. Docker Compose: redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ---------- FastAPI ----------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------- Auth (initial admin) ----------
INITIAL_ADMIN_EMAIL=admin@finresearch.local
INITIAL_ADMIN_PASSWORD=admin_password_change_me

# ---------- Frontend (web) ----------
VITE_API_BASE_URL=http://localhost:8000

# ---------- Data sources ----------
# yfinance is anonymous; add tokens here if you integrate paid sources
YFINANCE_USER_AGENT=FinResearch-Agent/0.1
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=

# Domestic A-share sources (FRA-23). AkShare needs no token. Tushare Pro
# requires a registered token from https://tushare.pro; leave blank to disable
# the tushare source. (Install the libs with: uv sync --extra data-cn)
TUSHARE_TOKEN=

# ---------- LLM / Agent ----------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_REQUEST_TIMEOUT_SECONDS=60

# ---------- Worker ----------
RQ_QUEUE_DEFAULT=default
RQ_QUEUE_DATA=data_sync
RQ_QUEUE_BACKTEST=backtest

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FORMAT=json
